# Postgres connection (Supabase). Use the pooled connection string for DATABASE_URL
# and the direct (non-pooled) connection string for DIRECT_URL — Prisma migrations
# need a direct connection, but the app should use the pooler at runtime.
DATABASE_URL="postgresql://postgres:password@localhost:5432/postgres"
DIRECT_URL="postgresql://postgres:password@localhost:5432/postgres"

# Auth.js
# Generate with: npx auth secret
AUTH_SECRET=""

# Discord OAuth app (https://discord.com/developers/applications)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Comma-separated Discord user IDs that should be auto-provisioned as ACTIVE admins
# on first sign-in. Needed to bootstrap the first admin, since no one exists yet to
# approve them. Right-click your own account in Discord (Developer Mode on) to copy it.
INITIAL_ADMIN_DISCORD_IDS=""

# Public base URL of the deployed app, used to build links in Discord
# announcements (e.g. a direct link to the prediction form). Defaults to
# localhost for local dev.
APP_URL="http://localhost:3000"

# Powers both the /pl-predictor slash command and season-lifecycle
# announcements ("predictions are open", etc) — both post through the same
# bot identity. Same Discord application as above — add a Bot in the
# Developer Portal's "Bot" tab to get DISCORD_BOT_TOKEN, and copy
# DISCORD_PUBLIC_KEY from "General Information". DISCORD_GUILD_ID is your
# server's ID (enable Developer Mode, right-click the server icon -> Copy
# Server ID) and makes command registration instant instead of global (up to
# 1hr to propagate). DISCORD_CHANNEL_ID is the channel to post announcements
# to (right-click the channel -> Copy Channel ID); the bot's role needs
# "Send Messages" permission there (Server Settings -> Roles), which isn't
# granted automatically when the bot is invited. Leave DISCORD_CHANNEL_ID
# blank to skip announcements entirely.
DISCORD_BOT_TOKEN=""
DISCORD_PUBLIC_KEY=""
DISCORD_GUILD_ID=""
DISCORD_CHANNEL_ID=""

# Vercel Blob storage for admin-uploaded quote screenshots. Auto-provisioned
# and written to .env.local by `vercel blob create-store <name> --access
# public --yes` — no manual setup needed once a store is linked to the
# project.
BLOB_READ_WRITE_TOKEN=""
